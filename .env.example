# Convex deployment shared with portfolio-build (public site).
# Get this from your Convex dashboard after `npx convex dev` (or `convex deploy`).
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Single-admin login password. Used by /api/admin/auth to issue a session cookie.
ADMIN_PASSWORD=change-me

# HMAC key that signs session cookies. Generate with:
#   openssl rand -hex 32
ADMIN_SECRET=change-me
